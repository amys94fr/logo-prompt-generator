[6.27, "o", "\u001b[35m└──────────────────────────────\u001b[0m\r\n"]
[6.57, "o", "\r\n"]
[6.57, "o", "\u001b[33mQ\u001b[0m What sector does your brand operate in?\r\n"]
[6.57, "o", "   \u001b[36m 1.\u001b[0m Technology / SaaS\r\n"]
[6.57, "o", "   \u001b[36m 2.\u001b[0m Restaurant / Cafe / Food\r\n"]
[6.57, "o", "   \u001b[36m 3.\u001b[0m Fashion / Luxury\r\n"]
[6.57, "o", "   \u001b[36m 4.\u001b[0m Finance / Banking / Insurance\r\n"]
[6.57, "o", "   \u001b[36m 5.\u001b[0m Health / Wellness / Fitness\r\n"]
[6.57, "o", "   \u001b[36m 6.\u001b[0m Education / Training\r\n"]
[6.57, "o", "   \u001b[36m 7.\u001b[0m Art / Design / Creative\r\n"]
[6.57, "o", "   \u001b[36m 8.\u001b[0m \u001b[2m... 8 more\u001b[0m\r\n"]
