[3.17, "o", "\u001b[36m════════════════════════════════════════════════════════════════\u001b[0m\r\n"]
[3.17, "o", "\u001b[1m\u001b[36m  Logo Prompt Generator: DALL-E 3 / Midjourney / SDXL\u001b[0m\r\n"]
[3.17, "o", "\u001b[36m════════════════════════════════════════════════════════════════\u001b[0m\r\n"]
[3.17, "o", "\u001b[90mAnswer the 8 questions to generate a tailored prompt.\u001b[0m\r\n"]
[4.17, "o", "\r\n"]
[4.17, "o", "\u001b[35m┌─ Step 1/8 \u001b[0m\r\n"]
[4.17, "o", "\u001b[1m\u001b[35m│  Brand identity\u001b[0m\r\n"]
[4.17, "o", "\u001b[35m└──────────────────────────────\u001b[0m\r\n"]
[4.67, "o", "\r\n"]
[4.67, "o", "\u001b[33mQ\u001b[0m What is the name of your brand?\r\n"]
[4.67, "o", "\u001b[32m > \u001b[0m"]
