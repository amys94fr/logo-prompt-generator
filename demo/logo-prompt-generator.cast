[8.04, "o", "\r\n"]
[8.04, "o", "\u001b[35m┌─ Step 3/8 \u001b[0m\r\n"]
[8.04, "o", "\u001b[1m\u001b[35m│  Logo type\u001b[0m\r\n"]
[8.04, "o", "\u001b[35m└──────────────────────────────\u001b[0m\r\n"]
[8.04, "o", "\r\n"]
[8.04, "o", "\u001b[33mQ\u001b[0m What type of logo do you want?\r\n"]
[8.04, "o", "   \u001b[36m 1.\u001b[0m Pictorial mark (icon only, like Apple)\r\n"]
[8.04, "o", "   \u001b[36m 2.\u001b[0m Wordmark (stylized text, like Google)\r\n"]
[8.04, "o", "   \u001b[36m 3.\u001b[0m Lettermark (initials, like HBO)\r\n"]
[8.04, "o", "   \u001b[36m 4.\u001b[0m Combination mark (icon + text, like Adidas)\r\n"]
[8.04, "o", "   \u001b[36m 5.\u001b[0m Emblem (closed badge, like Starbucks)\r\n"]
[8.04, "o", "   \u001b[36m 6.\u001b[0m \u001b[2m... 3 more\u001b[0m\r\n"]
[8.04, "o", "\u001b[32m > \u001b[0m"]
[8.84, "o", "4"]
[9.26, "o", "\r\n"]
[9.41, "o", "\r\n"]
